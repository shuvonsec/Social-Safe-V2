generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Case {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  name      String
  email     String
  phone     String?
  platform  String
  urgency   String
  message   String
  status    String   @default("new")
  locale    String   @default("en-MY")
}
